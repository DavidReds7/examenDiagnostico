# Backend (copiar a backend/.env)
DJANGO_SECRET_KEY=cambiar-por-clave-secreta-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=biblioteca_crud
MYSQL_USER=biblioteca_app
MYSQL_PASSWORD=cambiar_password

MYSQL_CONN_MAX_AGE=60
API_THROTTLE_ANON=300/minute

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
